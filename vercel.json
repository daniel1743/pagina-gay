{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.chactivo.com"
        }
      ],
      "destination": "https://chactivo.com/:path*",
      "permanent": true
    },
    {
      "source": "/chat/hablar-primero",
      "destination": "/chat/principal",
      "permanent": true
    },
    {
      "source": "/chat/hablar-primero/",
      "destination": "/chat/principal",
      "permanent": true
    },
    {
      "source": "/chat/mas-30",
      "destination": "/mas-30",
      "permanent": true
    },
    {
      "source": "/chat/mas-30/",
      "destination": "/mas-30",
      "permanent": true
    },
    {
      "source": "/chat/santiago",
      "destination": "/santiago",
      "permanent": true
    },
    {
      "source": "/chat/santiago/",
      "destination": "/santiago",
      "permanent": true
    },
    {
      "source": "/chat/es-main",
      "destination": "/es",
      "permanent": true
    },
    {
      "source": "/chat/es-main/",
      "destination": "/es",
      "permanent": true
    },
    {
      "source": "/chat/br-main",
      "destination": "/br",
      "permanent": true
    },
    {
      "source": "/chat/br-main/",
      "destination": "/br",
      "permanent": true
    },
    {
      "source": "/chat/mx-main",
      "destination": "/mx",
      "permanent": true
    },
    {
      "source": "/chat/mx-main/",
      "destination": "/mx",
      "permanent": true
    },
    {
      "source": "/chat/ar-main",
      "destination": "/ar",
      "permanent": true
    },
    {
      "source": "/chat/ar-main/",
      "destination": "/ar",
      "permanent": true
    },
    {
      "source": "/chat-gay-santiago-centro",
      "destination": "/santiago",
      "permanent": true
    },
    {
      "source": "/chat-gay-santiago-centro/",
      "destination": "/santiago",
      "permanent": true
    },
    {
      "source": "/anonymous-forum",
      "destination": "/chat/principal",
      "permanent": true
    },
    {
      "source": "/anonymous-forum/",
      "destination": "/chat/principal",
      "permanent": true
    },
    {
      "source": "/foro-gay",
      "destination": "/chat/principal",
      "permanent": true
    },
    {
      "source": "/foro-gay/",
      "destination": "/chat/principal",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api|_next|assets|static|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://chactivo.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-Requested-With, Content-Type, Authorization"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/anonymous-chat",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, follow"
        }
      ]
    },
    {
      "source": "/anonymous-chat/",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, follow"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
