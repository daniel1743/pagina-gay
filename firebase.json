{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/anonymous-chat",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, follow"
          }
        ]
      },
      {
        "source": "/anonymous-chat/",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, follow"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "geolocation=(self), microphone=(), camera=()"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/modal-mx",
        "destination": "/mx",
        "type": 301
      },
      {
        "source": "/modal-mx/",
        "destination": "/mx",
        "type": 301
      },
      {
        "source": "/modal-arg",
        "destination": "/ar",
        "type": 301
      },
      {
        "source": "/modal-arg/",
        "destination": "/ar",
        "type": 301
      },
      {
        "source": "/modal-es",
        "destination": "/es",
        "type": 301
      },
      {
        "source": "/modal-es/",
        "destination": "/es",
        "type": 301
      },
      {
        "source": "/modal-br",
        "destination": "/br",
        "type": 301
      },
      {
        "source": "/modal-br/",
        "destination": "/br",
        "type": 301
      },
      {
        "source": "/chat/hablar-primero",
        "destination": "/chat/principal",
        "type": 301
      },
      {
        "source": "/chat/hablar-primero/",
        "destination": "/chat/principal",
        "type": 301
      },
      {
        "source": "/chat/mas-30",
        "destination": "/mas-30",
        "type": 301
      },
      {
        "source": "/chat/mas-30/",
        "destination": "/mas-30",
        "type": 301
      },
      {
        "source": "/chat/santiago",
        "destination": "/santiago",
        "type": 301
      },
      {
        "source": "/chat/santiago/",
        "destination": "/santiago",
        "type": 301
      },
      {
        "source": "/chat/es-main",
        "destination": "/es",
        "type": 301
      },
      {
        "source": "/chat/es-main/",
        "destination": "/es",
        "type": 301
      },
      {
        "source": "/chat/br-main",
        "destination": "/br",
        "type": 301
      },
      {
        "source": "/chat/br-main/",
        "destination": "/br",
        "type": 301
      },
      {
        "source": "/chat/mx-main",
        "destination": "/mx",
        "type": 301
      },
      {
        "source": "/chat/mx-main/",
        "destination": "/mx",
        "type": 301
      },
      {
        "source": "/chat/ar-main",
        "destination": "/ar",
        "type": 301
      },
      {
        "source": "/chat/ar-main/",
        "destination": "/ar",
        "type": 301
      },
      {
        "source": "/chat-gay-santiago-centro",
        "destination": "/santiago",
        "type": 301
      },
      {
        "source": "/chat-gay-santiago-centro/",
        "destination": "/santiago",
        "type": 301
      },
      {
        "source": "/anonymous-forum",
        "destination": "/chat/principal",
        "type": 301
      },
      {
        "source": "/anonymous-forum/",
        "destination": "/chat/principal",
        "type": 301
      },
      {
        "source": "/foro-gay",
        "destination": "/chat/principal",
        "type": 301
      },
      {
        "source": "/foro-gay/",
        "destination": "/chat/principal",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
